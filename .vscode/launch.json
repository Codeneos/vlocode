// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: vscode-extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--disable-extensions",
                "--verbose",
                "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
            ],
            "outFiles": ["${workspaceFolder}/packages/vscode-extension/dist/**/*.js"],
            "pauseForSourceMap": true,
            "skipFiles": ["<node_internals>/**/*", "async_hooks.js", "inspector_async_hook.js"],
            "preLaunchTask": "build-extension",
            "smartStep": true,
            "sourceMaps": true,
            "autoAttachChildProcesses": true
        },
        {
            "type": "node",
            "request": "launch",
            "program": "${workspaceRoot}/packages/cli/dist/cli.mjs",
            "name": "Debug: CLI",
            "args": ["--help", "--debug"],
            "outFiles": ["${workspaceRoot}/packages/cli/dist/**/*.mjs"],
            "preLaunchTask": "watch-cli",
            "smartStep": true,
            "sourceMaps": true
        },
        {
            "type": "node",
            "request": "launch",
            "showAsyncStacks": true,
            "program": "${workspaceRoot}/packages/cli/dist/cli.mjs",
            "name": "Debug: CLI-impacted-tests (node)",
            "args": [
                "impacted-tests",
                "../src/core/classes/dataAccess/SObjectRepository.cls",
                "--sources", "../kpn/kpn_esmee/src",
                "--depth", "3"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/cli/dist/**/*.mjs"
            ],
            "preLaunchTask": "watch-cli",
            "smartStep": true,
            "sourceMaps": true
        },
        {
            "type": "node",
            "request": "launch",
            "showAsyncStacks": true,
            "program": "${workspaceRoot}/packages/cli/dist/cli.mjs",
            "name": "Debug: CLI-convert (node)",
            "args": [
                "convert",
                "../vlocode/.test-deploy/activationError/OmniScript",
                "-u", "peter@curlybracket.l.dnd "
            ],
            "outFiles": [
                "${workspaceFolder}/packages/cli/dist/**/*.mjs"
            ],
            "preLaunchTask": "watch-cli",
            "smartStep": true,
            "sourceMaps": true
        },
        {
            "type": "node",
            "request": "launch",
            "showAsyncStacks": true,
            "program": "${workspaceRoot}/packages/cli/dist/cli.mjs",
            "name": "Debug: CLI-deploy (node)",
            "args": [
                "deploy",
                "${workspaceRoot}/.test-deploy/activationError/OmniScript",
            ],
            "outFiles": [
                "${workspaceFolder}/packages/cli/dist/**/*.mjs"
            ],
            "preLaunchTask": "watch-cli",
            "smartStep": true,
            "sourceMaps": true
        },
        {
            "type": "node",
            "request": "launch",
            "showAsyncStacks": true,
            "program": "${workspaceRoot}/packages/cli/dist/cli.mjs",
            "name": "Debug: CLI-export (node)",
            "args": [
                "export",
                "-q", "select Id from Product2 Limit 10", 
                "-d", "sbqq-export.yaml",
                "--expand"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/cli/dist/**/*.mjs"
            ],
            "preLaunchTask": "watch-cli",
            "smartStep": true,
            "sourceMaps": true
        },
        {
            "name": "Debug: Build Commands",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/build/buildCommands.ts",
                "./package.json",
                "./commands.yaml"
            ],
            "runtimeArgs": ["-r", "ts-node/register"],
            "cwd": "${workspaceRoot}",
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "TS_NODE_IGNORE": "false"
            }
        },
        {
            "name": "Debug: Build Metadata Types",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/packages/salesforce/build/buildMetadataTypes.ts",
                "./metadata.xml"
            ],
            "runtimeArgs": ["-r", "ts-node/register"],
            "cwd": "${workspaceRoot}/packages/salesforce/build",
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "TS_NODE_IGNORE": "false"
            }
        },
        {
            "name": "Debug: Build (extension)",
            "request": "launch",
            "runtimeArgs": ["run-script", "build"],
            "cwd": "${workspaceRoot}/packages/vscode-extension",
            "runtimeExecutable": "npm",
            "skipFiles": ["<node_internals>/**"],
            "type": "node"
        },
        {
            "name": "Debug: SASS Compiler",
            "type": "node",
            "request": "launch",
            "args": [
                "${workspaceRoot}/packages/sass/dist/sass-compiler.js",
            ],
            "cwd": "${workspaceRoot}/packages/sass/dist",
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}
