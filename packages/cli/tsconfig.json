{
    "extends": "../../tsconfig",
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "bundler",
        "outDir": "dist",
        "declaration": true,
        "noEmit": true,
        "declarationMap": true,
        "allowImportingTsExtensions": true
    },
    "exclude": ["../../build/**/*.ts"],
    "include": ["src/**/*", "../../build/**/*.ts", "tsdown.config.mts"]
}
