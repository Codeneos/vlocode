{
    "extends": "../../tsconfig",
    "compilerOptions": {
        "module": "preserve",
        "target": "es2022",
        "moduleResolution": "bundler",
        "outDir": "lib",
        "sourceMap": true,
        "declaration": false,
        "allowArbitraryExtensions": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "types": ["node", "jest"],
        "typeRoots": ["./types", "./node_modules/@types", "../../node_modules/@types"]
    },
    "include": ["src/**/*.ts", "../../build/**/*.ts", "tsdown.config.mts"]
}
