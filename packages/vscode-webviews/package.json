{
    "name": "@vlocode/vscode-webviews",
    "version": "2.0.3",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm build:datapack && pnpm build:datamapper && pnpm build:integration-procedure",
        "build:datapack": "ng build datapack-editor --configuration production",
        "build:datamapper": "ng build datamapper-editor --configuration production",
        "build:integration-procedure": "ng build integration-procedure-editor --configuration production",
        "build:preview": "ng build editor-preview --configuration development",
        "preview": "ng serve editor-preview --configuration development --port 4200",
        "watch": "pnpm run --parallel --stream --no-bail \"/^watch:/\"",
        "watch:datapack": "ng build datapack-editor --watch --configuration development",
        "watch:datamapper": "ng build datamapper-editor --watch --configuration development",
        "watch:integration-procedure": "ng build integration-procedure-editor --watch --configuration development",
        "clean": "shx rm -rf ../vscode-extension/resources/datapack-editor ../vscode-extension/resources/datamapper-editor ../vscode-extension/resources/integration-procedure-editor"
    },
    "author": {
        "name": "Peter van Gulik",
        "email": "peter@curlybracket.nl"
    },
    "dependencies": {
        "@angular/common": "^21.2.11",
        "@angular/compiler": "^21.2.11",
        "@angular/core": "^21.2.11",
        "@angular/forms": "^21.2.11",
        "@angular/platform-browser": "^21.2.11",
        "@vlocode/vlocity": "workspace:*",
        "@vscode/codicons": "^0.0.45",
        "monaco-editor": "^0.55.1",
        "rxjs": "^7.8.2",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@angular/build": "^21.2.9",
        "@angular/cli": "^21.2.9",
        "sass": "^1.93.0",
        "shx": "^0.3.4",
        "typescript": "catalog:"
    }
}
