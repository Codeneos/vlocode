{
    "entryPoints": [
        "../packages/core/src/index.ts",
        "../packages/util/src/index.ts",
        "../packages/salesforce/src/index.ts",
        "../packages/vlocity-deploy/src/index.ts",
        "../packages/vlocity/src/index.ts",
        "../packages/omniscript/src/index.ts"
    ],
    "projectDocuments": [
        "../docs/README.md",
        "../docs/concepts.md",
        "../docs/cli.md",
        "../docs/export.md",
        "../docs/export-definitions.md",
        "../docs/import.md",
        "../docs/deployment-specs.md"
    ],
    "plugin": ["typedoc-plugin-rename-defaults"],
    "highlightLanguages": ["xml", "json", "typescript", "ts", "js", "javascript", "shell", "bash", "yaml", "yml"],
    "externalSymbolLinkMappings": {
        "typescript": {
            "Array.sort": "#",
            "Array.some": "#",
            "Array.prototype.some": "#",
            "Array.prototype.join": "#",
            "encodeURIComponent": "#",
            "Array.prototype.splice": "#",
            "Array.prototype.map": "#",
            "Map": "#",
            "Array": "#"
        },
        "@vlocode/util": {
            "event": "#"
        },
        "@vlocode/salesforce": {
            "TokenReplacementPlugin": "#"
        }
    },
    "externalPattern": ["../packages/vscode-extension/**/*", "../packages/cli/**/*"],
    "cname": "vlocode.curlybracket.nl",
    "exclude": "**/*.test.ts",
    "readme": "SITE.md",
    "out": "site",
    "hideGenerator": true,
    "excludePrivate": false,
    "excludeExternals": true,
    "includeVersion": true,
    "githubPages": true,
    "pretty": true,
    "cleanOutputDir": true,
    "tsconfig": "./tsconfig.typedoc.json"
}
